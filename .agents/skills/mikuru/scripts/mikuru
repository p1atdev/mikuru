#!/usr/bin/env bash

set -euo pipefail

skill_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
bundle="$skill_dir/assets/mikuru.js"

if ! command -v bun >/dev/null 2>&1; then
  printf 'mikuru skill: required command not found: bun\n' >&2
  exit 127
fi

if [[ ! -f "$bundle" ]]; then
  printf 'mikuru skill: bundled executable not found: %s\n' "$bundle" >&2
  exit 1
fi

exec bun "$bundle" "$@"
