{
  "name": "mikuru",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "mikuru": "./dist/mikuru"
  },
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "start": "bun index.ts",
    "test": "bun test",
    "test:live": "MIKURU_LIVE=1 bun test tests/live-sites.test.ts",
    "verify-sites": "bun scripts/verify-sites.ts",
    "import:sherlock": "bun scripts/import-sherlock.ts",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun build index.ts --compile --outfile dist/mikuru",
    "build:skill": "bun build index.ts --target bun --minify --outfile .agents/skills/mikuru/assets/mikuru.js",
    "format": "oxfmt '!.agents/skills/mikuru/assets/**'",
    "lint": "oxlint --deny-warnings --ignore-pattern '.agents/skills/mikuru/assets/**'"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@cliffy/command": "npm:@jsr/cliffy__command",
    "@cliffy/table": "npm:@jsr/cliffy__table",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
