{
  "name": "mikuru",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "mikuru": "./dist/mikuru"
  },
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "start": "bun index.ts",
    "test": "bun test",
    "test:live": "MIKURU_LIVE=1 bun test tests/live-sites.test.ts",
    "verify-sites": "bun scripts/verify-sites.ts",
    "import:sherlock": "bun scripts/import-sherlock.ts",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun build index.ts --compile --outfile dist/mikuru",
    "format": "oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
